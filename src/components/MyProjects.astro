---
import { getCollection } from "astro:content";
import { Image } from "astro:assets"; // IMPORTANTE: Recuperamos el componente Image

const allProjects = await getCollection("projects");
---

<section id="projects" class="w-full max-w-7xl mx-auto px-4 sm:px-6 md:px-12 py-24 md:py-32 relative z-20">
    
    {/* Header de la sección */}
    <div class="mb-12">
        <h2 class="text-xs sm:text-sm font-code text-dev-muted uppercase tracking-[0.2em]">
            // MIS PROYECTOS
        </h2>
    </div>

    {/* Lista de Proyectos */}
    <div class="flex flex-col gap-12">
        {allProjects.map((project) => (
            <article class="flex flex-col gap-6 w-full project-grid p-6 md:p-12 transition-colors duration-500 border border-dev-border hover:border-dev-primary/40">
                
                {/* Categoría / Eyebrow */}
                <div class="text-xs font-code text-dev-muted uppercase tracking-widest">
                    // {project.data.category}
                </div>
                
                {/* Título */}
                <h3 class="text-4xl md:text-5xl font-code font-bold text-dev-primary">
                    {project.data.title}
                </h3>

                {/* Descripción */}
                <p class="text-base md:text-lg text-dev-muted max-w-3xl leading-relaxed">
                    {project.data.description}
                </p>

                {/* Stack de Tecnologías (Con Iconos Restaurados) */}
                <div class="flex flex-wrap gap-4 md:gap-6 mt-2">
                    {project.data.technologies?.map((tech) => (
                        <span class="flex items-center gap-2 text-xs font-code text-dev-muted uppercase tracking-widest">
                            {/* Renderizamos la imagen solo si existe en el markdown */}
                            {tech.icon && (
                                <Image 
                                    src={tech.icon} 
                                    alt={tech.name} 
                                    class="w-4 h-4 object-contain opacity-80 group-hover:opacity-100 transition-opacity" 
                                />
                            )}
                            {tech.name}
                        </span>
                    ))}
                </div>

                {/* Botones de Acción */}
                <div class="flex flex-col sm:flex-row items-start sm:items-center gap-6 mt-4">
                    
                    {/* Botón Ver Detalles (Icono de Ojo) */}
                    <a href="#"class="flex items-center gap-2 text-sm font-code text-dev-primary hover:text-orange-500 transition-colors duration-300">
                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-5 h-5">
                          <path stroke-linecap="round" stroke-linejoin="round" d="M2.036 12.322a1.012 1.012 0 0 1 0-.639C3.423 7.51 7.36 4.5 12 4.5c4.638 0 8.573 3.007 9.963 7.178.07.207.07.431 0 .639C20.577 16.49 16.64 19.5 12 19.5c-4.638 0-8.573-3.007-9.963-7.178Z" />
                          <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" />
                        </svg>
                        Ver Detalles
                    </a>

                    {/* Botón GitHub (Icono de Código) */}
                    {project.data.githubLink && (
                        <a href={project.data.githubLink} target="_blank" rel="noopener noreferrer" class="flex items-center gap-2 text-sm font-code text-dev-primary hover:text-orange-500 transition-colors duration-300">
                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"/><path d="M9 18c-4.51 2-5-2-7-2"/></svg>
                            GitHub
                        </a>
                    )}
                </div>

            </article>
        ))}
    </div>
</section>